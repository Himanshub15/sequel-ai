{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SQL Studio",
  "version": "0.1.0",
  "identifier": "com.himanshu.sql-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SQL Studio",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

